# ============================================
# ZabbixNodes Backend - Environment Variables
# ============================================

# Database Configuration
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/zabbixnodes

# Security Keys (mínimo 32 caracteres)
# Gerar com: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long!!

# Encryption Key para dados sensíveis
# Gerar com: python3 -c "import os; print(os.urandom(16).hex())"
ENCRYPTION_KEY=dc793222263d62730c11634a476f0079

# Admin User
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# CORS - Origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# API Configuration
API_RATE_LIMIT=100

# Application Settings
DEBUG=False
ENVIRONMENT=development

# Logging
LOG_LEVEL=info

# Workers (número de processos uvicorn)
WORKERS=4

# Port
PORT=8000
HOST=0.0.0.0
